# K2 Java R&D Demo — Environment Configuration
#
# Copy to .env and fill in your values. All variables are optional;
# built-in defaults are used when absent.

# --- Credentials (required for live K2 operations) ---
# K2_API_KEY=your-k2-api-key
# OPENAI_API_KEY=your-openai-api-key
# TAVILY_API_KEY=your-tavily-api-key

# --- K2 API ---
# K2_API_HOST=https://api.knowledge2.ai
# K2_BASE_URL=                    # legacy alias for K2_API_HOST
# K2_PROJECT_ID=<your-project-uuid>
# K2_PROJECT_NAME=java-rd-demo

# --- Corpus IDs (override defaults for each role) ---
# K2_FLINK_DOCS_CORPUS_ID=<uuid>
# K2_FLINK_CODE_CORPUS_ID=<uuid>
# K2_FLINK_CODE_PART2_CORPUS_ID=<uuid>
# K2_FLINK_CODE_PART3_CORPUS_ID=<uuid>
# K2_KAFKA_DOCS_CORPUS_ID=<uuid>
# K2_KAFKA_CODE_CORPUS_ID=<uuid>
# K2_GUIDES_CORPUS_ID=<uuid>

# --- Evaluation Runs ---
# Evaluation scripts write artifacts (prompts, answers, scorecards) to
# .eval-runs/ by default (gitignored). Override with --out-dir.

# --- MCP Server ---
# K2_MCP_BACKEND=sdk          # sdk | kubectl | auto
# K2_MCP_NAMESPACE=k2-mvp
# K2_MCP_DEPLOYMENT=deploy/k2-mvp-api-internal
# K2_MCP_LOG_PATH=             # optional tool call log path
